[
  {
    "label": "AWS secret access key env var",
    "text": "AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY",
    "shouldMatch": true
  },
  {
    "label": "aws secret key in YAML",
    "text": "aws_secret_key: \"wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY\"",
    "shouldMatch": true
  },
  {
    "label": "low-entropy value with AWS context (rejected by entropy)",
    "text": "AWS_SECRET_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
    "shouldMatch": false
  },
  {
    "label": "git SHA without AWS context",
    "text": "commit a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0",
    "shouldMatch": false
  },
  {
    "label": "too short",
    "text": "AWS_SECRET_KEY=shortkey",
    "shouldMatch": false
  }
]
