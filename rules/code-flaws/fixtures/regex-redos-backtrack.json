    "text": "const re = /[a-z]+[0-9]*/;",
    "shouldMatch": false
  },
  {
    "label": "anchored group repetition (ab+)* is linear-time",
    "text": "const re = /(ab+)*/;",
    "shouldMatch": false
  },
