{
  "specVersion": 1,
  "id": "secrets/aws-access-key",
  "name": "AWS Access Key ID",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "\\b(AKIA|ASIA|AROA|AIDA|ANPA|ANVA|APKA)[A-Z0-9]{16}\\b",
    "flags": "g"
  },
  "postValidators": ["entropy"],
  "examples": ["AKIAIOSFODNN7EXAMPLE"]
}
