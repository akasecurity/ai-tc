{
  "specVersion": 1,
  "id": "core-financial/swift",
  "name": "SWIFT/BIC code",
  "category": "financial",
  "severity": "high",
  "matcher": {
    "type": "regex",
    "pattern": "\\b(?:swift|bic)\\b[\\s#:=-]{0,8}([A-Z]{6}[A-Z0-9]{2}(?:[A-Z0-9]{3})?)\\b",
    "flags": "gi",
    "captureGroup": 1
  },
  "examples": ["SWIFT: BOFAUS3N", "BIC: CHASGB2LXXX"]
}
