{
  "specVersion": 1,
  "id": "secrets/vault-token",
  "name": "HashiCorp Vault token",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "\\b(?:hvs\\.[A-Za-z0-9\\-_]{20,50}|s\\.[A-Za-z0-9\\-_]{20,50})\\b",
    "flags": "g"
  },
  "postValidators": ["entropy"],
  "examples": ["hvs.AbCdEfGhIjKlMnOpQrStUvWxYz1234567890"]
}
