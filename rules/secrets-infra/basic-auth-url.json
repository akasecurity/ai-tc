{
  "specVersion": 1,
  "id": "secrets-infra/basic-auth-url",
  "name": "URL with embedded basic auth credentials",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "https?://[A-Za-z0-9_%\\-]+:[A-Za-z0-9_%\\-]+@[A-Za-z0-9.\\-]+",
    "flags": "g"
  },
  "examples": ["https://user:password@example.com/path"]
}
