{
  "specVersion": 1,
  "id": "secrets-infra/kubeconfig-token",
  "name": "Kubernetes kubeconfig embedded token",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "\\b(?:client-(?:certificate|key)-data|token):\\s+([A-Za-z0-9+/=_.-]{20,})",
    "flags": "g",
    "captureGroup": 1
  },
  "examples": ["token: eyJhbGciOiJSUzI1NiIsImtpZCI6IiJ9..."]
}
