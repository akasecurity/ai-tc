{
  "specVersion": 1,
  "id": "core-phi/hipaa-identifier",
  "name": "HIPAA standard identifier (health plan member/group number)",
  "category": "phi",
  "severity": "high",
  "matcher": {
    "type": "regex",
    "pattern": "\\b(?:health\\s+plan|beneficiary|claim\\s+number|member\\s+id|subscriber|group\\s*id|group\\s*number)[:\\s]*[A-Za-z0-9]{8,20}\\b",
    "flags": "gi"
  },
  "examples": ["Health Plan: XYZ123456789", "Member ID: ABC987654321"]
}
