{
  "specVersion": 1,
  "id": "secrets-infra/docker-config-auth",
  "name": "Docker config.json auth (base64-encoded)",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "\"auth\"\\s*:\\s*\"[A-Za-z0-9+/]{12,}={0,2}\"",
    "flags": "g"
  },
  "examples": ["\"auths\": {\"https://index.docker.io/v1/\": {\"auth\": \"dXNlcjpwYXNzd29yZA==\"}}"]
}
