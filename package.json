{
  "name": "ai-tc",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.1",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "setup": "pnpm install && lefthook install"
  },
  "devDependencies": {
    "@akasecurity/eslint-config": "workspace:*",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "eslint": "^9.0.0",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^5.8.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1",
      "js-yaml": "^4.2.0",
      "postcss": "^8.5.10"
    }
  }
}
