[
  {
    "label": "camelCase JSON field not covered by password-field's fixed keyword list",
    "text": "{\"authToken\": \"aBc123XyZ789kLmNoPqRsTuVwXyZ1234567890\"}",
    "shouldMatch": true
  },
  {
    "label": "shell-style env var not covered by env-key-value's fixed keyword list",
    "text": "ENCRYPTION_KEY=aBc123XyZ789kLmNoPqRsTuVwXyZ1234567890",
    "shouldMatch": true
  },
  {
    "label": "YAML config field",
    "text": "signingKey: aBc123XyZ789kLmNoPqRsTuVwXyZ1234567890",
    "shouldMatch": true
  },
  {
    "label": "quoted JSON field and value",
    "text": "\"clientSecret\": \"aBc123XyZ789kLmNoPqRsTuVwXyZ1234567890\"",
    "shouldMatch": true
  },
  {
    "label": "credential-shaped field with underscore label",
    "text": "REFRESH_TOKEN=aBc123XyZ789kLmNoPqRsTuVwXyZ1234567890",
    "shouldMatch": true
  },
  {
    "label": "high-entropy value on an unrelated hash-shaped field",
    "text": "\"commitHash\": \"aBc123XyZ789kLmNoPqRsTuVwXyZ1234567890\"",
    "shouldMatch": false
  },
  {
    "label": "high-entropy value on an unrelated id-shaped field",
    "text": "\"sessionId\": \"aBc123XyZ789kLmNoPqRsTuVwXyZ1234567890\"",
    "shouldMatch": false
  },
  {
    "label": "credential-shaped field but low-entropy value",
    "text": "token: abababababababababab",
    "shouldMatch": false
  },
  {
    "label": "credential-shaped field but value too short",
    "text": "token: abc12345",
    "shouldMatch": false
  },
  {
    "label": "prose mentioning secret/token with no key-value shape nearby",
    "text": "The secret token system uses rotating credentials for security audits.",
    "shouldMatch": false
  }
]
