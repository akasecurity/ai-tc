{
  "specVersion": 1,
  "id": "secrets/github-pat",
  "name": "GitHub Personal Access Token",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "\\bgh[psou]_[A-Za-z0-9]{36}\\b",
    "flags": "g"
  },
  "examples": ["ghp_aBcDeFgHiJkLmNoPqRsTuVwXyZ1234567890"]
}
