[
  {
    "label": "Cloudflare API token env var",
    "text": "CLOUDFLARE_API_TOKEN=kQ9fL2mP7xR4tY6wB1nC8vD3jH5sZ0aG2eU4iO7p",
    "shouldMatch": true
  },
  {
    "label": "cloudflare token in YAML",
    "text": "cloudflare_api_token: \"aZ3xQ9wE7rT2yU5iO8pA1sD4fG6hJ0kL2zX5cV8b\"",
    "shouldMatch": true
  },
  {
    "label": "40-char token without Cloudflare context",
    "text": "api_token=kQ9fL2mP7xR4tY6wB1nC8vD3jH5sZ0aG2eU4iO7p",
    "shouldMatch": false
  },
  {
    "label": "too short with context",
    "text": "CLOUDFLARE_API_KEY=12345",
    "shouldMatch": false
  }
]
