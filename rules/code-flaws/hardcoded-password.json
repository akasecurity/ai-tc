{
  "specVersion": 1,
  "id": "code-flaws/hardcoded-password",
  "name": "Hardcoded password in source code",
  "category": "code_flaw",
  "severity": "high",
  "matcher": {
    "type": "regex",
    "pattern": "(password|passwd|pwd)\\s*=\\s*[\"'][^\"']{3,}[\"']",
    "flags": "gi"
  },
  "postValidators": ["entropy"],
  "examples": ["password = \"Tr0ub4dor&3\"", "DB_PASSWORD = 'c0rr3ctH0rseBatt3ry'"]
}
