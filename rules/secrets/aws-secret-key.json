{
  "specVersion": 1,
  "id": "secrets/aws-secret-key",
  "name": "AWS Secret Access Key",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "aws[_.-]?secret[_.-]?(?:access[_.-]?)?key[\"'\\s:=]{1,5}([A-Za-z0-9/+]{40})",
    "flags": "gi",
    "captureGroup": 1
  },
  "postValidators": ["entropy"],
  "examples": ["AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"]
}
