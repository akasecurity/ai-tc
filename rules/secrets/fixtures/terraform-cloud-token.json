[
  {
    "label": "TFC token",
    "text": "TFE_TOKEN=AbCdEfGhIjKlMn.atlasv1.XyZ1234567890123456789012345678901234567890123456789012345678901234567890",
    "shouldMatch": true
  },
  {
    "label": "in credentials",
    "text": "token: XyZ9876543210A.atlasv1.AbcDef1234567890123456789012345678901234567890123456789012345678901234567890",
    "shouldMatch": true
  },
  {
    "label": "bad format",
    "text": "token: simple-token",
    "shouldMatch": false
  },
  {
    "label": "missing atlasv1",
    "text": "token: AbCdEfGhIjKlMnOp.other.XyZ1234567890",
    "shouldMatch": false
  }
]
