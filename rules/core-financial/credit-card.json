{
  "specVersion": 1,
  "id": "core-financial/credit-card",
  "name": "Credit/debit card number",
  "category": "financial",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "\\b(?:4[0-9]{12}(?:[0-9]{3})?|5[1-5][0-9]{14}|3[47][0-9]{13}|6(?:011|5[0-9]{2})[0-9]{12})\\b",
    "flags": "g"
  },
  "postValidators": ["luhn"],
  "examples": ["4111111111111111", "5500000000000004"]
}
