[
  {
    "label": "Azure storage",
    "text": "DefaultEndpointsProtocol=https;AccountName=mystorage;AccountKey=abc123==;EndpointSuffix=core.windows.net",
    "shouldMatch": true
  },
  {
    "label": "in env var",
    "text": "AZURE_CONNECTION=\"DefaultEndpointsProtocol=https;AccountName=prod;AccountKey=xyz789==\"",
    "shouldMatch": true
  },
  {
    "label": "not a connection string",
    "text": "DefaultEndpoint is not set",
    "shouldMatch": false
  },
  {
    "label": "incomplete",
    "text": "AccountName=test",
    "shouldMatch": false
  },
  {
    "label": "storage account key pair",
    "text": "AccountName=mystorage;AccountKey=abc123==",
    "shouldMatch": true
  },
  {
    "label": "service bus with shared access key",
    "text": "Endpoint=sb://myns.servicebus.windows.net/;SharedAccessKey=abc123==",
    "shouldMatch": true
  },
  {
    "label": "cosmos db account endpoint and key",
    "text": "AccountEndpoint=https://myacct.documents.azure.com:443/;AccountKey=abc123==",
    "shouldMatch": true
  },
  {
    "label": "camelCase endpoint identifiers with assignments",
    "text": "mcpEndpointLabel=summary;toEndpointSummary=trim",
    "shouldMatch": false
  },
  {
    "label": "keywords in prose without key=value shape",
    "text": "Endpoint config was updated;AccountName rotation is pending",
    "shouldMatch": false
  },
  {
    "label": "segments split across lines",
    "text": "AccountName=my\nstorage;AccountKey=abc123==",
    "shouldMatch": false
  },
  {
    "label": "generic endpoint without a second known key",
    "text": "Endpoint=https://api.example.com;timeout=30",
    "shouldMatch": false
  },
  {
    "label": "oversized value segment",
    "text": ";AccountKey=abc123==",
    "shouldMatch": false
  },
  {
    "label": "iot hub device connection string",
    "text": "HostName=myhub.azure-devices.net;SharedAccessKey=abc123==",
    "shouldMatch": true
  },
  {
    "label": "code building a connection string from placeholders",
    "text": "AccountName={accountName};AccountKey={accountKey}",
    "shouldMatch": false
  },
  {
    "label": "parser regex literal with capture groups",
    "text": "AccountName=(.*?);AccountKey=(.*?)",
    "shouldMatch": false
  }
]
