{
  "specVersion": 1,
  "id": "secrets/anthropic-api-key",
  "name": "Anthropic API key",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "\\bsk-ant-[A-Za-z0-9_-]{40,}",
    "flags": "g"
