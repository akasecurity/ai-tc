{
  "specVersion": 1,
  "id": "core-pii/ssn",
  "name": "US Social Security Number",
  "category": "pii",
  "severity": "high",
  "matcher": {
    "type": "regex",
    "pattern": "\\b(?!000|666|9\\d{2})\\d{3}[\\s\\-](?!00)\\d{2}[\\s\\-](?!0000)\\d{4}\\b",
    "flags": "g"
  },
  "examples": ["123-45-6789", "987 65 4321"]
}
