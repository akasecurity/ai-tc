[
  {
    "label": "Datadog API key",
    "text": "DD_API_KEY=12345678901234567890123456789012",
    "shouldMatch": true
  },
  {
    "label": "Datadog APP key",
    "text": "DD_APP_KEY=1234567890123456789012345678901234567890",
    "shouldMatch": true
  },
  {
    "label": "not a key",
    "text": "DD_API_KEY is not set",
    "shouldMatch": false
  },
  {
    "label": "too short",
    "text": "DD_API_KEY=short",
    "shouldMatch": false
  }
]
