{
  "specVersion": 1,
  "id": "secrets/openai-api-key",
  "name": "OpenAI API key",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "\\bsk-proj-[A-Za-z0-9]{20,60}\\b|\\bsk-[A-Za-z0-9]{40,55}\\b",
    "flags": "g"
  },
  "postValidators": ["entropy"],
  "examples": ["sk-proj-AbCdEfGhIjKlMnOpQrStUvWxYz1234567890AbCdEfGhIjK"]
}
