{
  "specVersion": 1,
  "id": "secrets-infra/password-field",
  "name": "JSON/YAML field with password value",
  "category": "secret",
  "severity": "high",
  "matcher": {
    "type": "regex",
    "pattern": "[\"']?\\b(?:password|passwd|pwd|pass|secret|token|api[_-]?key|apikey)\\b[\"']?\\s*:\\s*[\"']([^\"'\\n]{4,})[\"']",
    "flags": "gi",
    "captureGroup": 1
  },
  "examples": ["\"password\": \"supersecret123\""]
}
