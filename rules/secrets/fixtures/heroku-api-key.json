[
  {
    "label": "Heroku API key env var",
    "text": "HEROKU_API_KEY=3f8a1c2e-9b4d-4e6f-a1b2-c3d4e5f6a7b8",
    "shouldMatch": true
  },
  {
    "label": "in netrc with heroku host",
    "text": "machine api.heroku.com password 7d2e9f01-4a6b-4c8d-9e0f-1a2b3c4d5e6f",
    "shouldMatch": true
  },
  {
    "label": "generic UUID without Heroku context",
    "text": "uuid: 00000000-0000-0000-0000-000000000000",
    "shouldMatch": false
  },
  {
    "label": "request id without Heroku context",
    "text": "request-id: 12345678-1234-5678-9abc-def012345678",
    "shouldMatch": false
  },
  {
    "label": "too short",
    "text": "HEROKU_API_KEY=1234",
    "shouldMatch": false
  }
]
