{
  "specVersion": 1,
  "id": "core-phi/member-id",
  "name": "Health plan member ID",
  "category": "phi",
  "severity": "high",
  "matcher": {
    "type": "regex",
    "pattern": "\\bmember\\s*(?:id|number|no|#)\\s*[:#]?\\s*[A-Za-z0-9]{6,20}\\b",
    "flags": "gi"
  },
  "examples": ["Member ID: ABC987654321"]
}
