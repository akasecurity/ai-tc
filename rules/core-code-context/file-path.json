{
  "specVersion": 1,
  "id": "core-code-context/file-path",
  "name": "Absolute file path",
  "category": "code_context",
  "severity": "low",
  "matcher": {
    "type": "regex",
    "pattern": "/(?:etc|var|usr|opt|home|root|tmp|srv|mnt|bin|sbin|lib|proc|dev|boot)(?:/[A-Za-z0-9_.-]+)+|[A-Za-z]:\\\\(?:[A-Za-z0-9_.-]+\\\\?)+",
    "flags": "g"
  },
  "examples": ["/var/log/app.log", "/home/user/config.json", "C:\\Users\\admin\\config.yml"]
}
