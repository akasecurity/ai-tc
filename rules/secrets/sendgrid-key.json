{
  "specVersion": 1,
  "id": "secrets/sendgrid-key",
  "name": "SendGrid API key",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "\\bSG\\.[A-Za-z0-9_\\-]{20,60}\\b",
    "flags": "g"
  },
  "postValidators": ["entropy"],
  "examples": ["SG.AbCdEfGhIjKlMnOpQrStUvWxYzAbCdEfGhIjKlMnOpQrStUvWxYz"]
}
