{
  "specVersion": 1,
  "id": "core-phi/mrn",
  "name": "Medical Record Number",
  "category": "phi",
  "severity": "high",
  "matcher": {
    "type": "regex",
    "pattern": "\\b(?:MRN|MR#|medical\\s+record)[:\\s]*[A-Za-z0-9]{6,16}\\b",
    "flags": "gi"
  },
  "examples": ["MRN: 1234567890", "Medical Record: ABCD1234"]
}
