[
  {
    "label": "Python hardcoded high-entropy password",
    "text": "password = \"Tr0ub4dor&3secr3t!\"",
    "shouldMatch": true
  },
  {
    "label": "env variable assignment with real password",
    "text": "DB_PASSWORD = 'c0rr3ctH0rseBatt3ryStapl3'",
    "shouldMatch": true
  },
  {
    "label": "realistic password shorter than the API-key entropy window",
    "text": "pwd = \"Tr0ub4dor&3\"",
    "shouldMatch": true
  },
  {
    "label": "password read from environment",
    "text": "password = os.environ['DB_PASSWORD']",
    "shouldMatch": false
  },
  {
    "label": "short placeholder not passing entropy",
    "text": "password = \"abc\"",
    "shouldMatch": false
  },
  {
    "label": "low-entropy placeholder (entropy runs on the VALUE, not the whole assignment)",
    "text": "password = \"changeme\"",
    "shouldMatch": false
  },
  {
    "label": "repeated-character filler value",
    "text": "password = \"aaaaaaaaaaaaaaaaaaaaaaaa\"",
    "shouldMatch": false
  }
]
