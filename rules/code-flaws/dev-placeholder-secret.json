{
  "specVersion": 1,
  "id": "code-flaws/dev-placeholder-secret",
  "name": "Placeholder or default secret left in code",
  "category": "code_flaw",
  "severity": "high",
  "matcher": {
    "type": "keyword",
    "keywords": [
      "changeme",
      "placeholder",
      "your-secret",
      "dev-secret",
      "replace-me",
      "todo-secret"
    ],
    "caseSensitive": false
  },
  "requiresNearby": {
    "labels": ["key", "secret", "password", "token"],
    "windowChars": 80
  },
  "examples": ["SECRET_KEY = 'changeme'", "api_token = 'your-secret'"]
}
