{
  "specVersion": 1,
  "id": "secrets/pulumi-access-token",
  "name": "Pulumi access token",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "\\bpul-[A-Za-z0-9]{20,60}\\b",
    "flags": "g"
  },
  "postValidators": ["entropy"],
  "examples": ["pul-ABCdEfGhIjKlMnOpQrStUvWxYz1234567890"]
}
