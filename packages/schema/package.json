  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@aka/eslint-config": "workspace:*",
    "@types/node": "^25.9.3",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  }
}
