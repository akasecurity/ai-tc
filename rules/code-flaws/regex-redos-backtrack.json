{
  "specVersion": 1,
  "id": "code-flaws/regex-redos-backtrack",
  "name": "ReDoS via catastrophic backtracking pattern",
  "category": "code_flaw",
  "severity": "medium",
  "matcher": {
    "type": "regex",
    "pattern": "\\([^)]*[+*?][^)]*\\)[+*?]",
    "flags": "g"
  },
  "examples": ["/(a+)+/", "/(\\w+\\s*)+/"]
}
