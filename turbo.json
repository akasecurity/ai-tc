{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["tsconfig.base.json", "rules/**"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^typecheck"],
      "outputs": ["dist/**", "public/**", "scripts/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["build", "^build", "^typecheck"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
