{
  "specVersion": 1,
  "id": "core-phi/icd10-code",
  "name": "ICD-10 diagnosis code",
  "category": "phi",
  "severity": "medium",
  "matcher": {
    "type": "regex",
    "pattern": "(?:icd[- ]?10|diagnosis|\\bdx\\b).{0,12}?([A-Z][0-9]{2}(?:\\.[0-9]{1,4})?)\\b",
    "flags": "gi",
    "captureGroup": 1
  },
  "examples": ["ICD-10: I10", "Diagnosis code E11.9", "dx: J45.909"]
}
