{
  "specVersion": 1,
  "id": "code-flaws/eval-dynamic-exec",
  "name": "Dynamic code execution with user-controlled input",
  "category": "code_flaw",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "\\b(eval|exec)\\s*\\(\\s*(?!['\"`])",
    "flags": "g"
  },
  "requiresNearby": {
    "labels": ["input", "request", "param", "user", "query", "body"],
    "windowChars": 200
  },
  "examples": ["eval(request.body.code)", "exec(user_input)"]
}
