{
  "specVersion": 1,
  "id": "secrets/slack-token",
  "name": "Slack API token",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "\\b(?:xox[baprs]-[A-Za-z0-9]{10,60}|xapp-[A-Za-z0-9-]{10,60})\\b",
    "flags": "g"
  },
  "examples": ["xoxb-123456789012-123456789012-ABCdEfGhIjKlMnOpQrStUvWx"]
}
