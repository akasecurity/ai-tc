{
  "specVersion": 1,
  "id": "secrets/cloudflare-api-key",
  "name": "Cloudflare API token",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "cloudflare.{0,40}?[\"'\\s:=]([A-Za-z0-9_-]{40})",
    "flags": "gi",
    "captureGroup": 1
  },
  "postValidators": ["entropy"],
  "examples": ["CLOUDFLARE_API_TOKEN=kQ9fL2mP7xR4tY6wB1nC8vD3jH5sZ0aG2eU4iO7p"]
}
