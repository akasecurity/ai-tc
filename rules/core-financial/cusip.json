{
  "specVersion": 1,
  "id": "core-financial/cusip",
  "name": "CUSIP security identifier",
  "category": "financial",
  "severity": "medium",
  "matcher": {
    "type": "regex",
    "pattern": "\\bcusip\\b[\\s#:=-]{0,8}(\\d{3}[A-Z0-9]{2}[A-Z0-9*#@]\\d{2}[0-9])\\b",
    "flags": "gi",
    "captureGroup": 1
  },
  "examples": ["CUSIP: 037833100", "CUSIP 931142103"]
}
