{
  "specVersion": 1,
  "id": "secrets/digitalocean-token",
  "name": "DigitalOcean Personal Access Token",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "\\bdop_v1_[A-Za-z0-9]{64}\\b",
    "flags": "g"
  },
  "examples": ["dop_v1_1234567890123456789012345678901234567890123456789012345678901234"]
}
