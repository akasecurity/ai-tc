{
  "name": "@akasecurity/schema",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./zod": "./src/zod/index.ts",
    "./drizzle": "./src/drizzle/index.ts"
