{
  "name": "ai-tc",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.30.1",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build --filter=!@akasecurity/docs",
    "build:docs": "turbo run build --filter=@akasecurity/docs",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check:boundaries": "node scripts/check-oss-boundaries.mjs",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "setup": "pnpm install && lefthook install",
    "check:comments": "node scripts/check-comment-hygiene.mjs"
  },
  "devDependencies": {
    "@akasecurity/eslint-config": "workspace:*",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^19.0.0",
    "eslint": "^9.0.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.5.0",
    "turbo": "^2.9.18",
    "typescript": "^5.8.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1",
      "js-yaml": "^4.2.0",
      "postcss": "^8.5.10"
    }
  }
}
