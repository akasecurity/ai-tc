{
  "name": "@akasecurity/cli",
  "version": "0.8.0",
  "description": "AI Traffic Control — local-first CLI to inspect and govern AI agent traffic on your machine",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akasecurity/ai-tc.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/akasecurity/ai-tc/tree/main/cli",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "aka": "./dist/cli.js"
  },
  "files": [
    "dist",
    "web-ui"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "bundle:web-ui": "node scripts/bundle-web-ui.mjs",
    "prepack": "tsup && node scripts/bundle-web-ui.mjs",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ink": "^7.1.0",
    "next": "^15.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@akasecurity/dashboard-ui": "workspace:*",
    "@akasecurity/detections": "workspace:*",
    "@akasecurity/eslint-config": "workspace:*",
    "@akasecurity/local-ops": "workspace:*",
    "@akasecurity/persistence": "workspace:*",
    "@akasecurity/plugin-sdk": "workspace:*",
    "@akasecurity/schema": "workspace:*",
    "@akasecurity/web-ui": "workspace:*",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.10"
  }
}
