{
  "specVersion": 1,
  "id": "secrets/gitlab-token",
  "name": "GitLab Personal/Project Access Token",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "\\bglpat-[A-Za-z0-9\\-_]{20,40}\\b",
    "flags": "g"
  },
  "postValidators": ["entropy"],
  "examples": ["glpat-ABCdEfGhIjKlMnOpQrStUvWxYz1234567890"]
}
