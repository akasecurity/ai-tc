[
  {
    "label": "Discord token",
    "text": "DISCORD_TOKEN=NzkyNzI5MjU1MjU5MjU1MjU5.XyZvZw.ABCDEFGHIJKLMNOPQRSTUVWXYZa",
    "shouldMatch": true
  },
  {
    "label": "in env",
    "text": "export TOKEN=\"NzkyNzI5MjU1MjU5MjU1MjU5.XyZvZw.ABCDEFGHIJKLMNOPQRSTUVWXYZa\"",
    "shouldMatch": true
  },
  {
    "label": "not a token",
    "text": "AbCdEfGhIjKlMnOpQrStUvWx",
    "shouldMatch": false
  },
  {
    "label": "wrong format",
    "text": "token.abc.def",
    "shouldMatch": false
  }
]
