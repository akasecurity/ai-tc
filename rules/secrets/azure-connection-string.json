{
  "specVersion": 1,
  "id": "secrets/azure-connection-string",
  "name": "Azure connection string",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "(?:DefaultEndpointsProtocol|AccountName|AccountKey|SharedAccessSignature|Endpoint)[^;]+(?:;[^;]+){2,}",
    "flags": "g"
  },
  "examples": [
    "DefaultEndpointsProtocol=https;AccountName=mystorage;AccountKey=abc123==;EndpointSuffix=core.windows.net"
  ]
}
