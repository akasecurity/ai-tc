{
  "specVersion": 1,
  "id": "secrets/npm-token",
  "name": "npm access token",
  "category": "secret",
  "severity": "critical",
  "matcher": {
    "type": "regex",
    "pattern": "\\bnpm_[A-Za-z0-9]{36,60}\\b",
    "flags": "g"
  },
  "postValidators": ["entropy"],
  "examples": ["npm_AbCdEfGhIjKlMnOpQrStUvWxYz1234567890AbCdEfGhIjKlMnO"]
}
