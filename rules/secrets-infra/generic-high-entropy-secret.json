{
  "specVersion": 1,
  "id": "secrets-infra/generic-high-entropy-secret",
  "name": "Generic high-entropy secret assigned to a credential-shaped field",
  "category": "secret",
  "severity": "high",
  "matcher": {
    "type": "regex",
    "pattern": "[\"']?\\b([A-Za-z_][A-Za-z0-9_]{2,40})[\"']?\\s*[:=]\\s*[\"']?([A-Za-z0-9+/_\\-]{20,200})[\"']?",
    "flags": "g",
    "captureGroup": 2
  },
  "postValidators": ["entropy"],
  "requiresNearby": {
    "labels": [
      "secret",
      "token",
      "credential",
      "credentials",
      "password",
      "apikey",
      "api_key",
      "secretkey",
      "secret_key",
      "authtoken",
      "auth_token",
      "accesstoken",
      "access_token",
      "refreshtoken",
      "refresh_token",
      "clientsecret",
      "client_secret",
      "privatekey",
      "private_key",
      "signingkey",
      "signing_key",
      "sessiontoken",
      "session_token",
      "encryptionkey",
      "encryption_key"
    ],
    "windowChars": 60
  },
  "examples": [
    "authToken: \"aBc123XyZ789kLmNoPqRsTuVwXyZ1234567890\"",
    "ENCRYPTION_KEY=aBc123XyZ789kLmNoPqRsTuVwXyZ1234567890"
  ]
}
