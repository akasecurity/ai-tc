{
  "specVersion": 1,
  "id": "secrets-infra/api-key-header",
  "name": "API key in a custom HTTP header",
  "category": "secret",
  "severity": "high",
  "matcher": {
    "type": "regex",
    "pattern": "[\"']?\\bapi-?key\\b[\"']?\\s*:\\s*[\"']?([A-Za-z0-9+/_\\-.]{16,500})[\"']?",
    "flags": "gi",
    "captureGroup": 1
  },
  "postValidators": ["entropy"],
  "examples": ["X-Api-Key: aBc123XyZ789kLmNoPqRsTuVwXyZ1234567890"]
}
