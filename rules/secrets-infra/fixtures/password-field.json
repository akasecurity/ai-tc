[
  {
    "label": "JSON password",
    "text": "{\"user\": \"admin\", \"password\": \"supersecret123\"}",
    "shouldMatch": true,
    "expectedSpans": [
      {
        "start": 31,
        "end": 45
      }
    ]
  },
  {
    "label": "JSON token",
    "text": "{\"name\": \"test\", \"token\": \"ghp_abc123def456\"}",
    "shouldMatch": true,
    "expectedSpans": [
      {
        "start": 27,
        "end": 43
      }
    ]
  },
  {
    "label": "JSON api key",
    "text": "{\"apiKey\": \"sk-proj-ABC123DEF456\"}",
    "shouldMatch": true
  },
  {
    "label": "spoken about password",
    "text": "The password is encrypted",
    "shouldMatch": false
  },
  {
    "label": "not a field value",
    "text": "password field",
    "shouldMatch": false
  },
  {
    "label": "short JSON password, value is the span",
    "text": "{\"password\": \"hunter2\"}",
    "shouldMatch": true,
    "expectedSpans": [
      {
        "start": 14,
        "end": 21
      }
    ]
  }
]
